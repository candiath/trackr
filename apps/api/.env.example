# Cloud Postgres connection string (Neon, Supabase, etc.). Paste yours here in .env
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional: a direct (non-pooled) connection used for migrations. Some providers
# (e.g. Neon with PgBouncer) need it. To use it, also add `directUrl = env("DIRECT_URL")`
# to the datasource in prisma/schema.prisma. If you don't use pooling, ignore this.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Port the API listens on (the web app's VITE_API_URL must point here).
PORT=3000
