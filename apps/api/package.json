{
  "name": "@track/api",
  "version": "0.1.0",
  "private": true,
  "description": "Track REST API (Express + Prisma + Postgres)",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "tsx --env-file=.env src/server.ts",
    "start:prod": "prisma migrate deploy && tsx src/server.ts",
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:hash": "tsx scripts/hash-password.ts",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "@track/shared": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.0",
    "vitest": "^4.1.9"
  }
}
