{
  "name": "track",
  "version": "0.1.0",
  "private": true,
  "description": "Track — productividad y bienestar (tareas, hábitos, recaídas y mood)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n shared,web -c blue,green \"npm:dev:shared\" \"npm:dev:web\"",
    "dev:shared": "npm run dev -w @track/shared",
    "dev:web": "npm run dev -w @track/web",
    "build": "npm run build -w @track/shared && npm run build -w @track/web",
    "lint": "npm run lint -w @track/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
