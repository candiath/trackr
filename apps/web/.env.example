# Base URL of the API. The centralized HTTP client reads it to reach the backend.
# Use localhost for local dev, or your machine's LAN IP to test from a phone.
# Base URL of the API.
# - Local dev (separate Vite server): point it at the API, e.g. http://localhost:3000.
# - Production: the API server itself serves this build (same origin over Tailscale),
#   so leave it EMPTY — requests then go to the same origin the app was loaded from.
VITE_API_URL=http://localhost:3000
# VITE_API_URL=http://192.168.100.83:3000   # LAN IP, to test from a phone
# VITE_API_URL=                              # production: same-origin (served by the API)

# Shared secret sent on every API request; must match the API's SYNC_SECRET.
VITE_SYNC_SECRET=change-me
