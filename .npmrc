# The Render build runs the whole monorepo build, which type-checks the web app
# (tsc + vite build) and therefore needs devDependencies (vite, vitest, @types/*).
# With NODE_ENV=production, `npm install` omits devDependencies by default, so the
# build fails resolving those types. `include=dev` forces them to be installed.
# It only affects install time — the runtime `start:prod` installs nothing — so
# this has no effect on the production runtime.
include=dev
