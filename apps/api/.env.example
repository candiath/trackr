# Cloud Postgres connection string (Neon, Supabase, etc.). Paste yours here in .env
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional: a direct (non-pooled) connection used for migrations. Some providers
# (e.g. Neon with PgBouncer) need it. To use it, also add `directUrl = env("DIRECT_URL")`
# to the datasource in prisma/schema.prisma. If you don't use pooling, ignore this.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Port the API listens on (the web app's VITE_API_URL must point here).
PORT=3000

# --- Auth (single user) ---------------------------------------------------------
# Secret that signs the session JWT. Use a long random value; rotating it logs out
# all sessions. Generate one e.g. with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_JWT_SECRET="change-me"

# scrypt hash of your login password. Generate it with:
#   npm run auth:hash -- "your password"
# then paste the printed AUTH_PASSWORD_HASH="..." line here. The plaintext password
# is never stored.
AUTH_PASSWORD_HASH="change-me"

# Comma-separated allowed CORS origins. Unset = reflect request origin (local dev).
# REQUIRED in production: auth uses credentialed cookies, so the browser forbids a
# wildcard origin. Set it to the web app's origin.
# CORS_ORIGIN="https://track.example.com"

DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/123456789/xxxxxxxxx-xxxxxxxxxxxxxxxx"
