{
  // shared compiles to CommonJS because the api runs with type=commonjs; the same
  // dist works for Node without extra transpilation. The frontend doesn't use this
  // dist: it imports via a direct alias to the source (see the web vite.config).
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
